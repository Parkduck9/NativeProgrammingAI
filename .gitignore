# ==============================================
# C++ Win32 GDI — OthelloClient 전용 .gitignore
# ==============================================

# ==============================================
# 1. Visual Studio IDE 설정
# ==============================================

# VS가 실행 중 파일을 잠궈서 커밋 실패의 원인
.vs/

# 기기별 디버그 실행 경로가 달라 집↔인재원 충돌 원인
*.vcxproj.user

# IntelliSense 캐시 (기기마다 다르게 생성됨)
ipch/
.ipch/
*.ipch

# VS 기타 임시 파일
*.suo
*.userosscache
*.sln.docstates


# ==============================================
# 2. 빌드 산출물
# ==============================================

# 빌드 출력 폴더
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa]rm/
[Aa]rm64/

# 오브젝트 파일
*.obj

# 실행 파일
*.exe
*.ilk       # 증분 링크 파일 (수백 MB 가능)
*.pdb       # 디버그 심볼
*.map

# 미리 컴파일된 헤더 바이너리
*.pch
*.gch

# 리소스 컴파일러 임시 파일
*.aps
*.res


# ==============================================
# 3. 이 프로젝트 전용
# ==============================================

# 런타임에 자동 생성되는 기보 파일 (추적 불필요)
_replays/*.othello

# assets 바이너리는 추적 (게임 에셋은 공유 필요)
# _assets/ 는 ignore 하지 않음


# ==============================================
# 4. OS 캐시
# ==============================================

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini